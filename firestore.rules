rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ---- Validation helpers (shared by prod and _dev lane collections) ----
    // The /dev/ Pages lane reads/writes *_dev collections (see site/fb-env.js)
    // so dev experiments never touch prod data. Rules are identical.

    function validLeaderboard() {
      return request.resource.data.playerName is string
             && request.resource.data.weekId is string;
    }

    function validUserCreate() {
      return request.resource.data.displayName is string
             && request.resource.data.passphraseHash is string;
    }

    function validReview() {
      return request.resource.data.displayName is string
             && request.resource.data.rating is number
             && request.resource.data.rating >= 0.5
             && request.resource.data.rating <= 5;
    }

    function validProfile() {
      return request.resource.data.displayName is string;
    }

    function validReadingList() {
      return request.resource.data.displayName is string
             && request.resource.data.bookId is string
             && request.resource.data.status is string;
    }

    function validClub() {
      return request.resource.data.name is string
             && request.resource.data.name.size() >= 3
             && request.resource.data.name.size() <= 40
             && request.resource.data.hostDisplayName is string;
    }

    function validClubMember() {
      return request.resource.data.displayName is string
             && request.resource.data.role in ['host', 'moderator', 'member'];
    }

    function validClubRead() {
      return request.resource.data.bookTitle is string
             && request.resource.data.status in ['active', 'finished', 'abandoned'];
    }

    function validClubComment() {
      return request.resource.data.text is string
             && request.resource.data.text.size() > 0
             && request.resource.data.text.size() <= 2000
             && request.resource.data.displayName is string;
    }

    // ---- Prod collections ----

    match /leaderboard/{docId} {
      allow read: if true;
      allow write: if validLeaderboard();
    }

    match /users/{userId} {
      allow read: if true;
      allow create: if validUserCreate();
      // Allow update for password reset flag or setting new passphrase
      allow update: if true;
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow write: if validReview();
      allow delete: if true;
    }

    match /profiles/{userId} {
      allow read: if true;
      allow write: if validProfile();
    }

    match /readingLists/{docId} {
      allow read: if true;
      allow write: if validReadingList();
      allow delete: if true;
    }

    match /clubs/{clubId} {
      allow read: if true;
      allow create: if validClub();
      allow update: if true;
      allow delete: if true;

      match /members/{memberId} {
        allow read: if true;
        allow write: if validClubMember();
        allow delete: if true;
      }

      match /requests/{userId} {
        allow read: if true;
        allow write: if request.resource.data.displayName is string;
        allow delete: if true;
      }

      match /tbr/{itemId} {
        allow read: if true;
        allow write: if request.resource.data.bookTitle is string
                     && request.resource.data.suggestedBy is string;
        allow delete: if true;
      }

      match /reads/{readId} {
        allow read: if true;
        allow write: if validClubRead();
        allow delete: if true;

        match /comments/{commentId} {
          allow read: if true;
          allow create, update: if validClubComment();
          allow delete: if true;
        }

        match /progress/{userId} {
          allow read: if true;
          allow write: if request.resource.data.milestonePosition is number;
        }
      }
    }

    // ---- Dev lane collections (same shapes, separate data) ----

    match /leaderboard_dev/{docId} {
      allow read: if true;
      allow write: if validLeaderboard();
    }

    match /users_dev/{userId} {
      allow read: if true;
      allow create: if validUserCreate();
      allow update: if true;
    }

    match /reviews_dev/{reviewId} {
      allow read: if true;
      allow write: if validReview();
      allow delete: if true;
    }

    match /profiles_dev/{userId} {
      allow read: if true;
      allow write: if validProfile();
    }

    match /readingLists_dev/{docId} {
      allow read: if true;
      allow write: if validReadingList();
      allow delete: if true;
    }

    match /clubs_dev/{clubId} {
      allow read: if true;
      allow create: if validClub();
      allow update: if true;
      allow delete: if true;

      match /members/{memberId} {
        allow read: if true;
        allow write: if validClubMember();
        allow delete: if true;
      }

      match /requests/{userId} {
        allow read: if true;
        allow write: if request.resource.data.displayName is string;
        allow delete: if true;
      }

      match /tbr/{itemId} {
        allow read: if true;
        allow write: if request.resource.data.bookTitle is string
                     && request.resource.data.suggestedBy is string;
        allow delete: if true;
      }

      match /reads/{readId} {
        allow read: if true;
        allow write: if validClubRead();
        allow delete: if true;

        match /comments/{commentId} {
          allow read: if true;
          allow create, update: if validClubComment();
          allow delete: if true;
        }

        match /progress/{userId} {
          allow read: if true;
          allow write: if request.resource.data.milestonePosition is number;
        }
      }
    }
  }
}
