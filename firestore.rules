rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ---- Validation helpers (shared by prod and _dev lane collections) ----
    // The /dev/ Pages lane reads/writes *_dev collections (see site/fb-env.js)
    // so dev experiments never touch prod data. Rules are identical.

    function validLeaderboard() {
      return request.resource.data.playerName is string
             && request.resource.data.weekId is string;
    }

    function validUserCreate() {
      return request.resource.data.displayName is string
             && request.resource.data.passphraseHash is string;
    }

    function validReview() {
      return request.resource.data.displayName is string
             && request.resource.data.rating is number
             && request.resource.data.rating >= 0.5
             && request.resource.data.rating <= 5;
    }

    function validProfile() {
      return request.resource.data.displayName is string;
    }

    function validReadingList() {
      return request.resource.data.displayName is string
             && request.resource.data.bookId is string
             && request.resource.data.status is string;
    }

    // ---- Prod collections ----

    match /leaderboard/{docId} {
      allow read: if true;
      allow write: if validLeaderboard();
    }

    match /users/{userId} {
      allow read: if true;
      allow create: if validUserCreate();
      // Allow update for password reset flag or setting new passphrase
      allow update: if true;
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow write: if validReview();
      allow delete: if true;
    }

    match /profiles/{userId} {
      allow read: if true;
      allow write: if validProfile();
    }

    match /readingLists/{docId} {
      allow read: if true;
      allow write: if validReadingList();
      allow delete: if true;
    }

    // ---- Dev lane collections (same shapes, separate data) ----

    match /leaderboard_dev/{docId} {
      allow read: if true;
      allow write: if validLeaderboard();
    }

    match /users_dev/{userId} {
      allow read: if true;
      allow create: if validUserCreate();
      allow update: if true;
    }

    match /reviews_dev/{reviewId} {
      allow read: if true;
      allow write: if validReview();
      allow delete: if true;
    }

    match /profiles_dev/{userId} {
      allow read: if true;
      allow write: if validProfile();
    }

    match /readingLists_dev/{docId} {
      allow read: if true;
      allow write: if validReadingList();
      allow delete: if true;
    }
  }
}
