rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /leaderboard/{docId} {
      // Allow read access to all leaderboard entries
      allow read: if true;
      
      // Allow write if document has a valid playerName and weekId
      allow write: if request.resource.data.playerName is string
                   && request.resource.data.weekId is string;
    }

    match /users/{userId} {
      // Allow read access to all user documents
      allow read: if true;

      // Allow create only when document contains required fields
      allow create: if request.resource.data.displayName is string
                    && request.resource.data.passphraseHash is string;

      // Allow update for password reset flag or setting new passphrase
      allow update: if true;
    }

    match /reviews/{reviewId} {
      // Allow read access to all reviews
      allow read: if true;

      // Allow write when document has valid displayName and rating (0.5-5). Text is optional.
      allow write: if request.resource.data.displayName is string
                   && request.resource.data.rating is number
                   && request.resource.data.rating >= 0.5
                   && request.resource.data.rating <= 5;

      // Allow delete
      allow delete: if true;
    }

    match /profiles/{userId} {
      // Allow read access to all profiles (for community page)
      allow read: if true;

      // Allow write when document has valid displayName
      allow write: if request.resource.data.displayName is string;
    }

    match /readingLists/{docId} {
      // Allow read access to all reading list entries
      allow read: if true;

      // Allow write when document has valid fields
      allow write: if request.resource.data.displayName is string
                   && request.resource.data.bookId is string
                   && request.resource.data.status is string;

      // Allow delete
      allow delete: if true;
    }
  }
}
