# REQUIRED: your audiobooks root directory
ROOT_DIR=C:/Users/you/books

# Optional: where inspect_tags will recurse by default (falls back to ROOT_DIR if unset)
INSPECT_DIR=C:/Users/you/OpenAudible/books

# OPTIONAL: extra extensions (comma-separated) e.g. .m4b,.m4a,.mp4,.m4v
# EXTS_CSV=.m4b,.m4a,.mp4

# GitHub Pages output (relative paths are typical)
SITE_DIR=site
SITE_INDEX_NAME=index.html
SITE_CSV_NAME=catalog.csv

# NEW: where timestamped CSVs are stored locally
OUTPUT_DIR=output_files

# (Optional) Google Drive folder link to show on the page header
DRIVE_LINK=

# Dockerized OpenAudible pilot
# Keep this separate from a desktop OpenAudible library while the desktop app is running.
# To adopt the existing desktop library in place (no copy — see
# docs/MIGRATION_DESKTOP_TO_DOCKER.md), quit the desktop app first, then:
#   OPENAUDIBLE_DATA_DIR=C:\Users\nbasl\OpenAudible
OPENAUDIBLE_DATA_DIR=./runtime/openaudible
OPENAUDIBLE_PORT=3000
OPENAUDIBLE_PASSWORD=
OPENAUDIBLE_SYNC_INTERVAL_SECONDS=21600
OPENAUDIBLE_INITIAL_DELAY_SECONDS=180

# Wait until converted audio has stopped changing before uploading it.
MIN_FILE_AGE_SECONDS=300

# Replace a queued OpenAudible command not consumed after this long (crash recovery)
OPENAUDIBLE_STALE_COMMAND_SECONDS=900
